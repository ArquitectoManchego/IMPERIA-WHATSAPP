{
  "name": "omnifab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "powershell -Command \"Get-CimInstance Win32_Process -Filter \\\"Name = 'node.exe'\\\" | Where-Object { $_.CommandLine -like '*IMPERIA-WHATSAPP*' } | ForEach-Object { Stop-Process $_.ProcessId -Force -ErrorAction SilentlyContinue }; Stop-Process -Name chrome -Force -ErrorAction SilentlyContinue; Stop-Process -Name chromium -Force -ErrorAction SilentlyContinue; exit 0\"",
    "dev": "next dev -p 3010",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "next": "16.2.3",
    "next-auth": "^4.24.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "lucide-react": "^1.8.0",
    "puppeteer": "^24.40.0",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "whatsapp-web.js": "^1.34.6"
  }
